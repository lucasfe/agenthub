# Copy to `.env.local` and fill in the values to receive WhatsApp
# notifications via CallMeBot when Ralph starts and when it finishes a run.
#
# Get your key by following:
#   https://www.callmebot.com/blog/free-api-whatsapp-messages/

CALLMEBOT_KEY=
WHATSAPP_PHONE=

# Optional: customize the WhatsApp message sent when Ralph starts.
# Defaults to "🟢 Ralph started and is active." when unset.
# RALPH_STARTUP_MESSAGE=

# Web Push (mobile shell at /mobile) — VAPID public key. Frontend bundle.
# Generate the key pair with:
#   npx web-push generate-vapid-keys
# Copy the "Public Key" output here. The matching private key + the
# `mailto:` subject are server-side Supabase Edge Function secrets:
#   supabase secrets set VAPID_PRIVATE_KEY=<base64url-private-key>
#   supabase secrets set VAPID_SUBJECT=mailto:you@example.com
VITE_VAPID_PUBLIC_KEY=
